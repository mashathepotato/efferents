# Copy to .env and fill in. Only needed to run a LIVE lab (efferents start).
# The offline demo (`efferents demo smoke-lab`) needs none of these.

# Anthropic API key for the agent loop (Researcher / Coder / Analyst / Writer).
ANTHROPIC_API_KEY=

# Optional: path to the popper-probe checkout used by the falsifiability gate.
# Defaults to ~/Documents/popper-probe if unset.
# POPPER_PROBE_REPO=

# Optional: ntfy.sh topic for run notifications.
# NTFY_TOPIC=
